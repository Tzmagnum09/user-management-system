{% extends 'base.html.twig' %}

{% block title %}{{ 'Email Templates'|trans }} - {{ parent() }}{% endblock %}

{% block body %}
<div class="row">
    <div class="col-md-12 mb-4">
        <div class="d-flex justify-content-between align-items-center">
            <h2>{{ 'Email Templates Management'|trans }}</h2>
            {% if is_granted('ROLE_SUPER_ADMIN') or app.user.hasPermission('edit_email_templates') %}
                <a href="{{ path('admin_email_template_new') }}" class="btn btn-primary">
                    <i class="fas fa-plus"></i> {{ 'Create new template'|trans }}
                </a>
            {% endif %}
        </div>
    </div>

    <div class="col-md-12">
        <div class="card">
            <div class="card-header bg-gradient-primary text-white">
                <h4>{{ 'Email Templates'|trans }}</h4>
            </div>
            <div class="card-body">
                {% if templates|length > 0 %}
                    <div class="accordion" id="emailTemplatesAccordion">
                        {% for template_code, locales in templates %}
                            <div class="accordion-item mb-3">
                                <h2 class="accordion-header" id="heading{{ template_code }}">
                                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse{{ template_code }}" aria-expanded="false" aria-controls="collapse{{ template_code }}">
                                        <strong>{{ template_code|replace({'_': ' '})|title }}</strong>
                                    </button>
                                </h2>
                                <div id="collapse{{ template_code }}" class="accordion-collapse collapse" aria-labelledby="heading{{ template_code }}" data-bs-parent="#emailTemplatesAccordion">
                                    <div class="accordion-body">
                                        <div class="table-responsive">
                                            <table class="table table-bordered">
                                                <thead>
                                                    <tr>
                                                        <th>{{ 'Language'|trans }}</th>
                                                        <th>{{ 'Subject'|trans }}</th>
                                                        <th>{{ 'Last Updated'|trans }}</th>
                                                        <th>{{ 'Actions'|trans }}</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    {% for locale, template in locales %}
                                                        <tr>
                                                            <td>
                                                                {% if locale == 'fr' %}
                                                                    <span class="badge bg-primary">Français</span>
                                                                {% elseif locale == 'en' %}
                                                                    <span class="badge bg-success">English</span>
                                                                {% elseif locale == 'nl' %}
                                                                    <span class="badge bg-warning">Nederlands</span>
                                                                {% elseif locale == 'de' %}
                                                                    <span class="badge bg-danger">Deutsch</span>
                                                                {% else %}
                                                                    <span class="badge bg-secondary">{{ locale }}</span>
                                                                {% endif %}
                                                            </td>
                                                            <td>{{ template.subject }}</td>
                                                            <td>{{ template.updatedAt ? template.updatedAt|date('d/m/Y H:i') : template.createdAt|date('d/m/Y H:i') }}</td>
                                                            <td>
                                                                <div class="btn-group" role="group">
                                                                    <a href="{{ path('admin_email_template_preview', {'id': template.id}) }}" class="btn btn-sm btn-secondary" target="_blank">
                                                                        <i class="fas fa-eye"></i> {{ 'Preview'|trans }}
                                                                    </a>
                                                                    {% if is_granted('ROLE_SUPER_ADMIN') or app.user.hasPermission('edit_email_templates') %}
                                                                        <a href="{{ path('admin_email_template_edit', {'id': template.id}) }}" class="btn btn-sm btn-primary">
                                                                            <i class="fas fa-edit"></i> {{ 'Edit'|trans }}
                                                                        </a>
                                                                        <button type="button" class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#deleteModal{{ template.id }}">
                                                                            <i class="fas fa-trash"></i>
                                                                        </button>
                                                                    {% endif %}
                                                                </div>

                                                                <!-- Delete Modal -->
                                                                {% if is_granted('ROLE_SUPER_ADMIN') or app.user.hasPermission('edit_email_templates') %}
                                                                    <div class="modal fade" id="deleteModal{{ template.id }}" tabindex="-1" aria-labelledby="deleteModalLabel{{ template.id }}" aria-hidden="true">
                                                                        <div class="modal-dialog">
                                                                            <div class="modal-content">
                                                                                <div class="modal-header">
                                                                                    <h5 class="modal-title" id="deleteModalLabel{{ template.id }}">{{ 'Confirm Delete'|trans }}</h5>
                                                                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                                                </div>
                                                                                <div class="modal-body">
                                                                                    {{ 'Are you sure you want to delete this email template?'|trans }} <br>
                                                                                    <strong>{{ template.code }} ({{ locale }})</strong>
                                                                                </div>
                                                                                <div class="modal-footer">
                                                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                                                                                    <form action="{{ path('admin_email_template_delete', {'id': template.id}) }}" method="post">
                                                                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ template.id) }}">
                                                                                        <button type="submit" class="btn btn-danger">{{ 'Delete'|trans }}</button>
                                                                                    </form>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                {% endif %}
                                                            </td>
                                                        </tr>
                                                    {% endfor %}
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="alert alert-info">
                        <p>{{ 'No email templates found.'|trans }}</p>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}