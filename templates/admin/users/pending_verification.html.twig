{% extends 'base.html.twig' %}

{% block title %}{{ 'Users Pending Verification'|trans }} - {{ parent() }}{% endblock %}

{% block body %}
<div class="row">
    <div class="col-md-12 mb-4">
        <div class="d-flex justify-content-between align-items-center">
            <h2>{{ 'Users Pending Email Verification'|trans }}</h2>
            <div>
                <a href="{{ path('admin_users') }}" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> {{ 'Back to users'|trans }}
                </a>
                <a href="{{ path('admin_users_pending_approval') }}" class="btn btn-info">
                    <i class="fas fa-user-clock"></i> {{ 'Pending Approval'|trans }}
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-12">
        <div class="card">
            <div class="card-header bg-warning text-white">
                <h4>{{ 'Pending Email Verification'|trans }}</h4>
            </div>
            <div class="card-body">
                {% if users|length > 0 %}
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>{{ 'Name'|trans }}</th>
                                    <th>{{ 'Email'|trans }}</th>
                                    <th>{{ 'Username'|trans }}</th>
                                    <th>{{ 'Registration Date'|trans }}</th>
                                    <th>{{ 'Actions'|trans }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for user in users %}
                                    <tr>
                                        <td>{{ user.firstName }} {{ user.lastName }}</td>
                                        <td>{{ user.email }}</td>
                                        <td>{{ user.username }}</td>
                                        <td>{{ user.createdAt|date('d/m/Y H:i') }}</td>
                                        <td>
                                            <div class="btn-group" role="group">
                                                <form method="post" action="{{ path('admin_user_verify', {'id': user.id}) }}" class="d-inline">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('verify' ~ user.id) }}">
                                                    <button type="submit" class="btn btn-sm btn-success">
                                                        <i class="fas fa-check"></i> {{ 'Verify'|trans }}
                                                    </button>
                                                </form>
                                                <a href="{{ path('admin_user_edit', {'id': user.id}) }}" class="btn btn-sm btn-primary">
                                                    <i class="fas fa-edit"></i> {{ 'Edit'|trans }}
                                                </a>
                                                <button type="button" class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#deleteModal{{ user.id }}">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </div>

                                            <!-- Delete Modal -->
                                            <div class="modal fade" id="deleteModal{{ user.id }}" tabindex="-1" aria-labelledby="deleteModalLabel{{ user.id }}" aria-hidden="true">
                                                <div class="modal-dialog">
                                                    <div class="modal-content">
                                                        <div class="modal-header">
                                                            <h5 class="modal-title" id="deleteModalLabel{{ user.id }}">{{ 'Confirm Delete'|trans }}</h5>
                                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                        </div>
                                                        <div class="modal-body">
                                                            {{ 'Are you sure you want to delete this user?'|trans }} <br>
                                                            <strong>{{ user.firstName }} {{ user.lastName }} ({{ user.email }})</strong>
                                                        </div>
                                                        <div class="modal-footer">
                                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                                                            <form action="{{ path('admin_user_delete', {'id': user.id}) }}" method="post">
                                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                                                                <button type="submit" class="btn btn-danger">{{ 'Delete'|trans }}</button>
                                                            </form>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <div class="alert alert-success">
                        <p>{{ 'All users have verified their email addresses.'|trans }}</p>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}