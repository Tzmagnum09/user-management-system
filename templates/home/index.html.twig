{% extends 'base.html.twig' %}

{% block title %}{{ app_name }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        body {
            background-color: #f9f9f9;
        }
        
        .welcome-container {
            max-width: 700px;
            margin: 50px auto;
            background-color: white;
            border-radius: 10px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
            overflow: hidden;
        }
        
        .welcome-header {
            background: linear-gradient(135deg, #8e44ad, #3498db);
            color: white;
            padding: 12px;
            text-align: center;
        }
        
        .welcome-content {
            padding: 20px 25px 25px;
        }
        
        .logo-container {
            text-align: center;
            margin: 15px 0;
        }
        
        .logo-container img {
            height: 35px;
        }
        
        .welcome-description {
            text-align: center;
            margin: 15px 0 25px;
            color: #555;
            font-size: 0.9rem;
        }
        
        .features-container {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            margin-bottom: 25px;
        }
        
        .feature-card {
            flex: 1;
            min-width: 190px;
            border: 1px solid #eee;
            border-radius: 8px;
            padding: 15px;
            text-align: center;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        
        .feature-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        }
        
        .feature-icon {
            font-size: 2rem;
            margin-bottom: 8px;
        }
        
        .feature-icon-purple {
            color: #8e44ad;
        }
        
        .feature-icon-blue {
            color: #3498db;
        }
        
        .feature-icon-purple-dark {
            color: #6a1b9a;
        }
        
        .feature-title {
            font-size: 1rem;
            font-weight: bold;
            margin-bottom: 8px;
        }
        
        .feature-description {
            font-size: 0.85rem;
            color: #666;
        }
        
        .action-buttons {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-top: 15px;
        }
        
        .btn-register {
            background: linear-gradient(135deg, #8e44ad, #3498db);
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 5px;
            font-size: 0.9rem;
        }
        
        .btn-register:hover {
            opacity: 0.9;
            color: white;
        }
        
        .btn-login {
            background: white;
            color: #333;
            border: 1px solid #ddd;
            padding: 8px 20px;
            border-radius: 5px;
            font-size: 0.9rem;
        }
        
        .btn-login:hover {
            background: #f8f9fa;
        }
        
        /* Styles responsifs */
        @media (max-width: 768px) {
            .welcome-container {
                max-width: 95%;
                margin: 30px auto;
            }
            
            .features-container {
                flex-direction: column;
            }
            
            .feature-card {
                width: 100%;
            }
        }
    </style>
{% endblock %}

{% block navbar %}
<nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container">
        <a class="navbar-brand" href="{{ path('app_home') }}">
            <img src="{{ asset('images/logo.png') }}" height="30" alt="Dmqode.be">
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link active" href="{{ path('app_home') }}">{{ 'Accueil'|trans }}</a>
                </li>
            </ul>
            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_login') }}">
                        <i class="fas fa-sign-in-alt"></i> {{ 'Connexion'|trans }}
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_register') }}">
                        <i class="fas fa-user-plus"></i> {{ 'Inscription'|trans }}
                    </a>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" id="languageDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="fas fa-globe"></i> {{ app.request.locale|upper }}
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="languageDropdown">
                        {% set locales = app_supported_locales|split(',') %}
                        {% for locale in locales %}
                            <li><a class="dropdown-item {% if app.request.locale == locale %}active{% endif %}" href="{{ path(app.request.attributes.get('_route'), app.request.attributes.get('_route_params')|merge({_locale: locale})) }}">{{ locale|upper }}</a></li>
                        {% endfor %}
                    </ul>
                </li>
            </ul>
        </div>
    </div>
</nav>
{% endblock %}

{% block body %}
<div class="container">
    <div class="welcome-container">
        <div class="welcome-header">
            <h5 class="m-0">{{ 'Bienvenue sur notre site'|trans }}</h5>
        </div>
        
        <div class="welcome-content">
            <div class="logo-container">
                <img src="{{ asset('images/logo_black.png') }}" alt="Dmqode.be">
            </div>
            
            <div class="welcome-description">
                <p class="m-0">{{ 'Découvrez notre plateforme avec des fonctionnalités adaptées à vos besoins.'|trans }}</p>
            </div>
            
            <div class="features-container">
                <div class="feature-card">
                    <div class="feature-icon feature-icon-purple">
                        <i class="fas fa-user-check"></i>
                    </div>
                    <div class="feature-title">{{ 'Inscription simple'|trans }}</div>
                    <div class="feature-description">{{ 'Créez votre compte en quelques minutes et accédez à tous nos services.'|trans }}</div>
                </div>
                
                <div class="feature-card">
                    <div class="feature-icon feature-icon-blue">
                        <i class="fas fa-globe"></i>
                    </div>
                    <div class="feature-title">{{ 'Multilingue'|trans }}</div>
                    <div class="feature-description">{{ 'Notre site est disponible en français, néerlandais, anglais et allemand.'|trans }}</div>
                </div>
                
                <div class="feature-card">
                    <div class="feature-icon feature-icon-purple-dark">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <div class="feature-title">{{ 'Sécurisé'|trans }}</div>
                    <div class="feature-description">{{ 'Vos données sont protégées et sécurisées selon les dernières normes.'|trans }}</div>
                </div>
            </div>
            
            <div class="action-buttons">
                <a href="{{ path('app_register') }}" class="btn btn-register">{{ 'S\'inscrire'|trans }}</a>
                <a href="{{ path('app_login') }}" class="btn btn-login">{{ 'Se connecter'|trans }}</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block footer %}
<footer class="footer mt-5">
    <div class="container text-center">
        <p>&copy; {{ 'now'|date('Y') }} {{ app_name }}. {{ 'Tous droits réservés.'|trans }}</p>
    </div>
</footer>
{% endblock %}